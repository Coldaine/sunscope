{
  "name": "sunscope",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "test:core": "pnpm --filter @sunscope/core test",
    "test:ar": "pnpm --filter @sunscope/ar test",
    "test:sky": "pnpm --filter @sunscope/sky-detection test",
    "dev": "pnpm --filter @sunscope/mobile start",
    "dev:web": "pnpm --filter @sunscope/mobile start --web"
  },
  "devDependencies": {
    "@types/jest": "30.0.0",
    "@types/node": "24.3.0",
    "@types/react": "19.2.2",
    "@types/react-test-renderer": "19.1.0",
    "@types/suncalc": "1.9.2",
    "@types/tz-lookup": "6.1.2",
    "babel-preset-expo": "55.0.11",
    "jest": "29.7.0",
    "react": "19.2.0",
    "react-test-renderer": "19.2.0",
    "ts-jest": "29.4.6",
    "turbo": "2.5.8",
    "typescript": "5.9.2"
  }
}
